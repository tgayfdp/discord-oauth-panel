<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - <%= title %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #1a1a2e;
      color: #eee;
      min-height: 100vh;
    }
    .navbar {
      background: #16213e;
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid #0f3460;
    }
    .navbar h2 { color: #fff; }
    .navbar a { color: #aaa; text-decoration: none; }
    .navbar a:hover { color: #fff; }
    .container { max-width: 800px; margin: 2rem auto; padding: 0 1rem; }
    .profile-card {
      background: #16213e;
      border-radius: 12px;
      padding: 2rem;
      border: 1px solid #0f3460;
      margin-bottom: 1.5rem;
    }
    .profile-header {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      margin-bottom: 1.5rem;
    }
    .avatar {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      background: #5865F2;
    }
    .profile-info h3 { font-size: 1.5rem; }
    .profile-info p { color: #aaa; }
    .info-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
    .info-item {
      background: #1a1a2e;
      padding: 1rem;
      border-radius: 8px;
    }
    .info-item label { display: block; font-size: 0.8rem; color: #888; margin-bottom: 4px; }
    .info-item span { font-size: 1rem; color: #fff; }
    .card {
      background: #16213e;
      border-radius: 12px;
      padding: 2rem;
      border: 1px solid #0f3460;
      margin-bottom: 1.5rem;
    }
    .card h2 { margin-bottom: 1rem; color: #fff; }
    .card p { color: #aaa; margin-bottom: 1rem; }
    .btn {
      padding: 10px 24px;
      border: none;
      border-radius: 6px;
      font-size: 1rem;
      cursor: pointer;
      font-weight: 600;
      transition: background 0.2s;
      text-decoration: none;
      display: inline-block;
    }
    .btn-primary { background: #5865F2; color: #fff; }
    .btn-primary:hover { background: #4752C4; }
    .btn-success { background: #3ba55c; color: #fff; }
    .btn-success:hover { background: #2d8f4a; }
    .guilds-list { margin-top: 1rem; }
    .guild-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.75rem;
      background: #1a1a2e;
      border-radius: 6px;
      margin-bottom: 0.5rem;
    }
    .guild-item code { color: #5865F2; }
    .empty { color: #666; text-align: center; padding: 2rem; }
    .badge { display: inline-block; padding: 3px 10px; border-radius: 10px; font-size: 0.8rem; font-weight: 600; }
    .badge-synced { background: #3ba55c20; color: #3ba55c; border: 1px solid #3ba55c; }
  </style>
</head>
<body>
  <nav class="navbar">
    <h2>Discord Panel</h2>
    <div>
      <span style="color:#aaa;margin-right:1rem"><%= user.username %></span>
      <a href="/logout">Déconnexion</a>
    </div>
  </nav>
  <div class="container">
    <div class="profile-card">
      <div class="profile-header">
        <img class="avatar" src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="Avatar" onerror="this.style.display='none'">
        <div class="profile-info">
          <h3><%= user.username %></h3>
          <p>ID: <%= user.id %></p>
          <span class="badge badge-synced">Connecté</span>
        </div>
      </div>
      <div class="info-grid">
        <div class="info-item">
          <label>Email</label>
          <span><%= user.email || 'Non disponible' %></span>
        </div>
        <div class="info-item">
          <label>Dernière synchro</label>
          <span><%= new Date(user.updated_at).toLocaleString('fr-FR') %></span>
        </div>
      </div>
      <div style="margin-top: 1.5rem; text-align: center;">
        <form method="POST" action="/dashboard/sync">
          <button class="btn btn-success">Synchroniser mes informations</button>
        </form>
      </div>
    </div>

    <div class="card">
      <h2>Serveurs rejoints</h2>
      <p>Liste des serveurs où l'administration vous a ajouté.</p>
      <% if (guildsJoined.length > 0) { %>
        <div class="guilds-list">
          <% guildsJoined.forEach(function(gid) { %>
            <div class="guild-item">
              <span>Serveur: <code><%= gid %></code></span>
              <span class="badge badge-synced">Membre</span>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <p class="empty">Vous n'avez encore été ajouté à aucun serveur.</p>
      <% } %>
    </div>
  </div>
</body>
</html>
